rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function for admin check
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'cnr.pano@gmail.com';
    }

    // User requests
    match /users/{userId}/requests/{requestId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
    }
    
    // AI analyses
    match /users/{userId}/ai_analyses/{analysisId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
    }

    // Platform stats
    match /stats/{docId} {
      allow read: if true;
      allow write: if true; // Open for increments from any client
    }

    // Tickets
    match /tickets/{ticketId} {
      allow create: if request.auth != null;
      allow read: if (request.auth != null && resource.data.userId == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin();
    }
    
    // Activities
    match /activities/{activityId} {
      allow create: if request.auth != null;
      allow read: if (request.auth != null && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // Global Collections
    match /videos/{docId} { 
      allow read: if true; 
      allow write: if isAdmin();
    }
    match /docs/{docId} { 
      allow read: if true; 
      allow write: if isAdmin();
    }
    match /circuits/{docId} { 
      allow read: if true; 
      allow write: if isAdmin();
    }
    match /autocad/{docId} { 
      allow read: if true; 
      allow write: if isAdmin();
    }
    match /problems/{docId} {
      allow read: if true;
      allow write: if (request.auth != null) || isAdmin(); // Users can auto-publish problems
    }
    
    // Fallback
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
