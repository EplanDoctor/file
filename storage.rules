rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Eğitim videolarının herkes tarafından izlenebilmesi için okumayı serbest bırakıyoruz
      allow read: if true;
      
      // Sadece admin (cnr.pano@gmail.com) dosya yükleyebilir
      match /videos/{allVideos=**} {
        allow write: if request.auth != null && request.auth.token.email == 'cnr.pano@gmail.com';
      }
      
      // Diğer dokümanlar için de benzer kural (opsiyonel)
      match /docs/{allDocs=**} {
        allow write: if request.auth != null && request.auth.token.email == 'cnr.pano@gmail.com';
      }
    }
  }
}
