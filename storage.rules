rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Herkes dosyaları okuyabilir (videolar vs.)
    match /{allPaths=**} {
      allow read: if true;
    }
    
    // Admin her türlü dosyayı her yere yükleyebilir
    match /{allPaths=**} {
      allow write: if request.auth != null && 
                   (request.auth.token.email == 'cnr.pano@gmail.com' || 
                    request.auth.token.email_verified == true && request.auth.token.email == 'cnr.pano@gmail.com');
    }

    // Normal kullanıcılar sadece kendi klasörlerine (sorun/talep gönderirken) dosya yükleyebilir
    match /users/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
